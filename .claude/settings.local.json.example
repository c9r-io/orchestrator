{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(git status:*)",

      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker run:*)",
      "Bash(docker network:*)",
      "Bash(docker volume:*)",
      "Bash(docker inspect:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",

      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl rollout:*)",

      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(hey:*)",

      "WebSearch",
      "WebFetch(domain:github.com)"
    ]
  }
}

